# Deny-all strategy: ignore everything except specifically whitelisted files
/*

# 💡 Allow the following public files:
!/.gitignore
!/README.md
!/package.json
!/public/
!/banner.png
!/image_flux.jpg
!/image_gptimage.jpg
!/image_imagen-4.jpg
!/image_klein-large.jpg
!/image_klein.jpg

# 💡 Allow metadata/config files:
!/next.config.ts
!/tsconfig.json
!/postcss.config.mjs
!/eslint.config.mjs

# 💡 Allow styles:
!/src/
/src/*
!/src/app/
/src/app/*
!/src/app/globals.css

# ☢️ BUT still ignore standard junk (even if it matches above)
node_modules/
.next/
out/
build/
.env*
.DS_Store
*.pem
npm-debug.log*
.vercel
*.tsbuildinfo
next-env.d.ts
